# LLM provider: "gemini", "anthropic", "openai", or "stub" (no API key needed)
LLM_PROVIDER=stub

# Pick one depending on LLM_PROVIDER
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model names (override only if needed)
GOOGLE_MODEL=gemini-2.5-flash
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_MODEL=gpt-4o-mini

# Service binding
HOST=127.0.0.1
PORT=8001

# Shared secret with Spring Boot (rejects requests without matching header)
INTERNAL_API_KEY=change-me-to-a-long-random-string

# Read-only MySQL credentials for the SQL executor.
# Run setup-readonly-user.sql once to create this account.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ecommerce_db
DB_USER=chatbot_ro
DB_PASSWORD=chatbot_ro_password
DB_QUERY_TIMEOUT_SECONDS=10
